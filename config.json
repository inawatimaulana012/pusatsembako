{
  "app_name": "PUSAT SEMBAKO",
  "app_version": "1.0.0",
  "app_description": "Sistem Manajemen Toko Sembako",
  "flask_env": "production",
  "debug": false,
  "database": {
    "type": "sqlite",
    "name": "pusat_sembako.db"
  },
  "upload": {
    "folder": "writable/uploads",
    "max_size": 16777216,
    "allowed_extensions": [
      "jpg",
      "jpeg",
      "png",
      "gif",
      "webp"
    ]
  },
  "pagination": {
    "per_page": 20
  },
  "store_info": {
    "name": "Pusat Sembako",
    "address": "Jl. Raya No. 123",
    "phone": "0888 8888 8888",
    "email": "info@pusatsembako.com",
    "logo": "assets/logos/logo.png"
  },
  "payment_methods": {
    "bank_transfer": {
      "name": "Transfer Bank",
      "account_number": "1234567890",
      "account_holder": "Bapak ABCD",
      "bank_name": "Bank Central Asia"
    },
    "ewallet": {
      "name": "E-Wallet",
      "methods": [
        "Dana",
        "ShopeePay",
        "OVO",
        "GoPay"
      ],
      "phone": "0888 8888 8888"
    },
    "cash": {
      "name": "Cash",
      "enabled": true
    }
  },
  "colors": {
    "primary": "#2E7D32",
    "secondary": "#F9A825",
    "success": "#28a745",
    "warning": "#ffc107",
    "danger": "#dc3545",
    "info": "#17a2b8",
    "light": "#f8f9fa",
    "dark": "#343a40"
  },
  "features": {
    "member_system": true,
    "reward_system": true,
    "banner_system": true,
    "inventory_tracking": true,
    "multi_user": true
  }
}
